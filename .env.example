# ─── RSR Press Corps — Environment Configuration ─────────────────────────────
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Docker compose users: use the compose service name as host.
#   Example: postgresql://rsr:changeme@db:5432/rsr_press_corps
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# ─── Session ──────────────────────────────────────────────────────────────────
# Secret used to sign session cookies. Must be long, random, and unique.
# Generate with: openssl rand -hex 64
SESSION_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# ─── Operator (Command) Credentials ──────────────────────────────────────────
# Login credentials for the RSR Command dashboard.
# No defaults — these MUST be set explicitly.
OPERATOR_EMAIL=admin@yourdomain.com
OPERATOR_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ─── Bootstrap Operator (optional) ───────────────────────────────────────────
# Additional operator account for initial setup access.
# Leave blank to disable.
BOOTSTRAP_OPERATOR_EMAIL=
BOOTSTRAP_OPERATOR_PASSWORD=

# ─── Discord Webhook (optional) ───────────────────────────────────────────────
# If set, new applications trigger a Discord notification.
# Leave blank to disable.
DISCORD_WEBHOOK_URL=

# ─── API Server ───────────────────────────────────────────────────────────────
# Port the Express API server listens on (inside container: 8080).
PORT=8080

# ─── Node Environment ─────────────────────────────────────────────────────────
NODE_ENV=production
