**/dist/

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── Replit Platform ──────────────────────────────────────────────────────────
.cache/
.local/
.replit
.replitignore
.agents/
attached_assets/

# ─── IDE / OS ─────────────────────────────────────────────────────────────────
.idea/
.vscode/
.DS_Store
Thumbs.db

# ─── Dev-only Artifacts ───────────────────────────────────────────────────────
artifacts/mockup-sandbox/

# ─── Test Artifacts ───────────────────────────────────────────────────────────
test-results/
playwright-report/
